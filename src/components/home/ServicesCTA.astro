---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import crittercareImg from '../../assets/screenshots/crittercare.png';
import styles from './ServicesCTA.module.css';
import { getBookingMonth } from '../../shared/utils/content';

const bookingMonth = getBookingMonth();
---

<section class={`${styles.section} scroll-reveal`}>
  <h2 class={styles.title}>NEED A WEBSITE?</h2>
  <p class={styles.description}>
    I build fast, modern websites for small businesses in Denver, Lakewood, and across the Colorado
    Front Range. From custom business sites to landing pages and redesigns, built with the same
    engineering standards I bring to enterprise software.
  </p>
  <p class={styles.description}>
    Every site I build is hand-coded, mobile-first, and optimized for local search from day one.
    No templates, no page builders, no bloated platform costs. You get a site that loads in under
    a second, ranks in Google, and actually converts visitors into customers.
  </p>

  <ul class={styles.serviceList}>
    <li>Custom business websites and landing pages</li>
    <li>Website redesigns and performance upgrades</li>
    <li>Local SEO setup with Google Business Profile integration</li>
    <li>Mobile-first, responsive design tested on real devices</li>
    <li>Ongoing support and maintenance after launch</li>
  </ul>

  <div class={styles.proofSection}>
    <div class={styles.proofCard}>
      <div class={styles.browserFrame}>
        <div class={styles.browserBar}>
          <span class={styles.browserDot}></span>
          <span class={styles.browserDot}></span>
          <span class={styles.browserDot}></span>
          <span class={styles.browserUrl}>critter-care.com</span>
        </div>
        <Image
          src={crittercareImg}
          alt="Critter Care - pet sitting business website built by Bill Bergquist"
          width={600}
          height={375}
          class={styles.screenshot}
          loading="lazy"
        />
      </div>
      <p class={styles.proofCaption}>
        <a href="https://critter-care.com" target="_blank" rel="noopener noreferrer" class={styles.proofLink}>Critter Care</a>
        &mdash; a pet sitting business site with CMS, testimonials, and a simple contact form.
      </p>
    </div>
  </div>

  <div class={styles.trustSignals}>
    <span class={styles.trustItem}>&#10003; Booking for {bookingMonth}</span>
    <span class={styles.trustItem}>&#10003; Free consultation</span>
    <span class={styles.trustItem}>&#10003; Response within 1 business day</span>
  </div>

  <Button variant="primary" size="large" href="/services/">View Services &rarr;</Button>
</section>
