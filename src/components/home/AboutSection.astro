---
import GlowText from '../ui/GlowText.astro';
import Button from '../ui/Button.astro';
import styles from './AboutSection.module.css';
---

<section id="about" class={`${styles.section} scroll-reveal`}>
  <GlowText as="h2" size="medium" color="mint" class={styles.sectionTitle}>
    ABOUT ME
  </GlowText>
  <div class={styles.content}>
    <p class={styles.summary}>
      I'm a Staff Software Engineer with 14+ years of experience building web applications.
      Currently at Kasa, I lead frontend architecture while expanding into full stack development,
      internal tooling, and leveraging{' '}
      <span class="neon-text-orange">AI-assisted workflows</span> to help teams ship faster.
    </p>
    <p class={styles.summary}>
      My focus is on React, TypeScript, and Node.js, building performant, accessible interfaces
      and the developer tools that make teams more productive. I'm based in the Denver area and
      also help <a href="/services" class="neon-text-mint">local small businesses</a> get online with modern websites.
    </p>
    <div class={styles.highlights}>
      <div class={styles.highlight}>
        <span class={styles.highlightValue}>14+</span>
        <span class={styles.highlightLabel}>Years Experience</span>
      </div>
      <div class={styles.highlight}>
        <span class={styles.highlightValue}>Full Stack</span>
        <span class={styles.highlightLabel}>React & Node.js</span>
      </div>
      <div class={styles.highlight}>
        <span class={styles.highlightValue}>Staff Engineer</span>
        <span class={styles.highlightSub}>@ Kasa</span>
      </div>
    </div>
    <div class={styles.cta}>
      <Button variant="secondary" size="medium" href="/about">Learn More</Button>
    </div>
  </div>
</section>
