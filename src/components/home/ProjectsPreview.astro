---
import GlowText from '../ui/GlowText.astro';
import Button from '../ui/Button.astro';
import ProjectCard from '../projects/ProjectCard.astro';
import creaticalcImg from '../../assets/screenshots/creaticalc.png';
import sportsshortcutsImg from '../../assets/screenshots/sportsshortcuts.png';
import crittercareImg from '../../assets/screenshots/crittercare.png';
import styles from './ProjectsPreview.module.css';

const projects = [
  {
    title: 'CreatiCalc',
    description:
      'Free calculator suite for content creators. Estimate earnings, engagement rates, and sponsorship pricing across YouTube, Instagram, TikTok, Facebook, and X.',
    techStack: ['Next.js', 'React', 'TypeScript'],
    url: 'https://creaticalc.com',
    color: 'mint' as const,
    screenshot: creaticalcImg,
  },
  {
    title: 'Sports Shortcuts',
    description:
      'Injury and status alert generator for sports reporters. Create standardized NFL and NBA game-day messages.',
    techStack: ['React', 'TypeScript', 'Material UI'],
    url: 'https://sportsshortcuts.com',
    color: 'magenta' as const,
    screenshot: sportsshortcutsImg,
  },
  {
    title: 'Critter Care',
    description:
      'Pet sitting and dog walking business website. Service listings, testimonials, and CMS-powered content.',
    techStack: ['Astro', 'Tailwind CSS', 'Decap CMS'],
    url: 'https://critter-care.com',
    color: 'purple' as const,
    screenshot: crittercareImg,
  },
];
---

<section class={`${styles.section} scroll-reveal`}>
  <GlowText as="h2" size="medium" color="orange" class={styles.sectionTitle}>
    PROJECTS
  </GlowText>
  <p class={styles.blurb}>
    Web applications I've designed, built, and shipped, each solving a real problem with modern
    tech. From content creator tools to sports media utilities and small business sites, these
    projects showcase full-stack work with React, Next.js, Astro, and TypeScript.
  </p>
  <div class={styles.grid}>
    {
      projects.map((project) => (
        <div class="scroll-reveal-child">
          <ProjectCard {...project} />
        </div>
      ))
    }
  </div>
  <div class={styles.projectsLink}>
    <Button variant="secondary" href="/projects">View All Projects &rarr;</Button>
  </div>
</section>
