---
import GlowText from '../ui/GlowText.astro';
import Button from '../ui/Button.astro';
import CrapsGameCard from '../games/CrapsGameCard.astro';
import styles from './GameGrid.module.css';
---

<section id="games" class={`${styles.section} scroll-reveal`}>
  <GlowText as="h2" size="medium" color="magenta" class={styles.sectionTitle}>
    FEATURED GAME
  </GlowText>
  <p class={styles.blurb}>
    A playground for rapid AI-assisted development, combining my love of gaming with experiments in
    agentic workflows. Built entirely with AI pair programming using Claude Code, these browser games
    explore what's possible when you combine modern React with AI-powered development.
  </p>
  <div class={styles.grid}>
    <CrapsGameCard />
  </div>
  <div class={styles.arcadeLink}>
    <Button variant="secondary" href="/arcade">View My Arcade &rarr;</Button>
  </div>
</section>
