---
import { Image } from 'astro:assets';
import crittercareImg from '../../assets/screenshots/crittercare.png';
import creaticalcImg from '../../assets/screenshots/creaticalc.png';
import styles from './FeaturedWork.module.css';
---

<section class={`${styles.section} scroll-reveal`}>
  <p class={styles.label}>Featured Work</p>
  <h2 class={styles.heading}>Built, shipped, and running in production</h2>

  <div class={styles.projects}>
    <div class={`${styles.project} scroll-reveal-child`}>
      <div class={styles.browserFrame}>
        <div class={styles.browserBar}>
          <span class={styles.dot}></span>
          <span class={styles.dot}></span>
          <span class={styles.dot}></span>
          <span class={styles.browserUrl}>critter-care.com</span>
        </div>
        <div class={styles.screenshotWrap}>
          <Image
            src={crittercareImg}
            alt="Critter Care pet sitting business website"
            width={600}
            height={375}
            class={styles.screenshot}
            loading="lazy"
          />
          <div class={styles.screenshotOverlay}>
            <a href="https://critter-care.com" target="_blank" rel="noopener noreferrer" class={styles.viewProject}>
              View Live Site &#8599;
            </a>
          </div>
        </div>
      </div>
      <div class={styles.projectInfo}>
        <h3 class={styles.projectTitle}>Critter Care</h3>
        <p class={styles.projectDesc}>
          Pet sitting business site with CMS, testimonials, and a booking flow.
          Built to convert visitors into customers.
        </p>
        <div class={styles.techStack}>
          <span class={styles.tech}>Astro</span>
          <span class={styles.tech}>Tailwind</span>
          <span class={styles.tech}>CMS</span>
        </div>
      </div>
    </div>

    <div class={`${styles.project} scroll-reveal-child`}>
      <div class={styles.browserFrame}>
        <div class={styles.browserBar}>
          <span class={styles.dot}></span>
          <span class={styles.dot}></span>
          <span class={styles.dot}></span>
          <span class={styles.browserUrl}>creaticalc.com</span>
        </div>
        <div class={styles.screenshotWrap}>
          <Image
            src={creaticalcImg}
            alt="CreatiCalc content creator calculator suite"
            width={600}
            height={375}
            class={styles.screenshot}
            loading="lazy"
          />
          <div class={styles.screenshotOverlay}>
            <a href="https://creaticalc.com" target="_blank" rel="noopener noreferrer" class={styles.viewProject}>
              View Live Site &#8599;
            </a>
          </div>
        </div>
      </div>
      <div class={styles.projectInfo}>
        <h3 class={styles.projectTitle}>CreatiCalc</h3>
        <p class={styles.projectDesc}>
          Calculator suite for content creators. YouTube ad revenue estimates,
          engagement rate analysis, and sponsorship pricing.
        </p>
        <div class={styles.techStack}>
          <span class={styles.tech}>Next.js</span>
          <span class={styles.tech}>React</span>
          <span class={styles.tech}>TypeScript</span>
        </div>
      </div>
    </div>
  </div>

  <div class={styles.sectionCta}>
    <a href="/portfolio/" class={styles.sectionLink}>See all projects &rarr;</a>
  </div>
</section>
