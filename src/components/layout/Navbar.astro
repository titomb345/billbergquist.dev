---
import styles from './Navbar.module.css';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home', exact: true },
  { href: '/about', label: 'About', exact: false },
  { href: '/services', label: 'Services', exact: false },
  { href: '/projects', label: 'Projects', exact: false },
  { href: '/blog', label: 'Blog', exact: false },
  { href: '/arcade', label: 'Arcade', exact: false },
];
---

<header class={styles.navbar}>
  <a href="/" class={styles.logo}>
    <img src="/favicon.svg" alt="Bill Bergquist" class={styles.logoIcon} width="32" height="32" />
  </a>

  <nav class={styles.nav} aria-label="Primary navigation">
    {
      navLinks.map(({ href, label, exact }) => {
        const isActive = exact
          ? currentPath === href || currentPath === `${href}/` || currentPath === ''
          : currentPath.startsWith(href);
        return (
          <a href={href} class={`${styles.navLink} ${isActive ? styles.active : ''}`}>
            {label}
          </a>
        );
      })
    }
    <a
      href="/retro"
      id="nav-retro"
      class={`${styles.navLink} ${currentPath.startsWith('/retro') ? styles.active : ''}`}
      style="display:none"
    >
      Retro
    </a>
  </nav>

  <button
    class={styles.menuToggle}
    id="mobile-menu-toggle"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span class={styles.hamburgerLine}></span>
    <span class={styles.hamburgerLine}></span>
    <span class={styles.hamburgerLine}></span>
  </button>

  <div class={styles.mobileOverlay} id="mobile-overlay"></div>

  <nav class={styles.mobileNav} id="mobile-menu" aria-label="Mobile navigation">
    <div class={styles.mobileNavInner}>
      {
        navLinks.map(({ href, label, exact }) => {
          const isActive = exact
            ? currentPath === href || currentPath === `${href}/` || currentPath === ''
            : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class={`${styles.mobileNavLink} ${isActive ? styles.mobileActive : ''}`}
            >
              {label}
            </a>
          );
        })
      }
      <a
        href="/retro"
        id="nav-retro-mobile"
        class={`${styles.mobileNavLink} ${currentPath.startsWith('/retro') ? styles.mobileActive : ''}`}
        style="display:none"
      >
        Retro
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');

  function openMenu() {
    toggle?.classList.add('is-open');
    menu?.classList.add('is-open');
    overlay?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    toggle?.classList.remove('is-open');
    menu?.classList.remove('is-open');
    overlay?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.classList.contains('is-open');
    isOpen ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  // Close on nav link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // Show Retro link if user has a Clerk session
  function showRetroIfAuthed() {
    const uat = document.cookie.split('; ').find((c) => c.startsWith('__client_uat='));
    const value = uat?.split('=')[1];
    if (value && value !== '0') {
      document.getElementById('nav-retro')?.style.setProperty('display', '');
      document.getElementById('nav-retro-mobile')?.style.setProperty('display', '');
    }
  }
  showRetroIfAuthed();
</script>
