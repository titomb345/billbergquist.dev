---
import { Image } from 'astro:assets';
import crittercareImg from '../../assets/screenshots/crittercare.png';
import styles from './RecentWork.module.css';
---

<section class={styles.section}>
  <h2 class={styles.sectionTitle}>Recent Work</h2>
  <div class={styles.showcase}>
    <div class={styles.browserFrame}>
      <div class={styles.browserBar}>
        <span class={styles.browserDot}></span>
        <span class={styles.browserDot}></span>
        <span class={styles.browserDot}></span>
        <span class={styles.browserUrl}>critter-care.com</span>
      </div>
      <Image
        src={crittercareImg}
        alt="Critter Care - pet sitting business website built by Bill Bergquist"
        width={600}
        height={375}
        class={styles.screenshot}
        loading="lazy"
      />
    </div>
    <div class={styles.details}>
      <h3 class={styles.projectName}>Critter Care</h3>
      <span class={styles.projectType}>Local Business Website</span>
      <p class={styles.projectDescription}>
        Built a pet sitting and dog walking website from scratch. Fast, mobile-friendly, and
        designed to convert visitors into bookings. Includes service pages, pricing, testimonials,
        and a contact form with CMS-powered content.
      </p>
      <div class={styles.projectFooter}>
        <div class={styles.techList}>
          <span class={styles.techTag}>Astro</span>
          <span class={styles.techTag}>Tailwind CSS</span>
          <span class={styles.techTag}>Decap CMS</span>
        </div>
        <a href="https://critter-care.com" target="_blank" rel="noopener noreferrer" class={styles.projectLink}>
          Visit Site &rarr;
        </a>
      </div>
    </div>
  </div>
</section>
