---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import SectionDivider from '../components/ui/SectionDivider.astro';
import ServicesGrid from '../components/home/ServicesGrid.astro';
import FeaturedWork from '../components/home/FeaturedWork.astro';
import Process from '../components/home/Process.astro';
import ClosingCTA from '../components/home/ClosingCTA.astro';

const jsonLdPerson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://billbergquist.dev/#person',
  name: 'Bill Bergquist',
  jobTitle: 'Web Developer',
  description: 'Web developer in Denver, CO building fast, modern websites for small businesses. 14+ years of experience with React, TypeScript, and modern web technologies.',
  url: 'https://billbergquist.dev',
  image: 'https://billbergquist.dev/og/home.png',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Denver',
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  sameAs: [
    'https://github.com/titomb345',
    'https://www.linkedin.com/in/bill-bergquist/',
  ],
});

const jsonLdWebsite = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://billbergquist.dev/#website',
  name: 'Bill Bergquist',
  url: 'https://billbergquist.dev',
});
---

<Layout
  title="Bill Bergquist — Denver Web Developer for Small Businesses"
  description="Denver web developer building fast, modern websites for small businesses. Custom sites, redesigns, and local SEO. 14+ years of experience. Free consultation."
  canonical="/"
  jsonLd={[jsonLdPerson, jsonLdWebsite]}
  ogImage="/og/home.png"
  geoRegion="US-CO"
  geoPlacename="Denver, CO"
>
  <Hero />
  <SectionDivider color="orange" />
  <ServicesGrid />
  <SectionDivider color="orange" />
  <FeaturedWork />
  <SectionDivider color="orange" />
  <Process />
  <ClosingCTA />
</Layout>
