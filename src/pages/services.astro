---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import GlowText from '../components/ui/GlowText.astro';
import Card from '../components/ui/Card.astro';
import SectionDivider from '../components/ui/SectionDivider.astro';
import ContactForm from '../components/services/ContactForm';
import CredibilitySection from '../components/services/CredibilitySection.astro';
import RecentWork from '../components/services/RecentWork.astro';
import headshot from '../assets/headshot.png';
import styles from './ServicesPage.module.css';

const bookingMonth = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toLocaleString('en-US', {
  month: 'long',
});

const services = [
  {
    icon: '01',
    title: 'Business Websites',
    description:
      'A professional site that helps your Denver or Lakewood business get found online. Fast on every device, easy to navigate, and built to get you more calls and bookings.',
    color: 'mint',
  },
  {
    icon: '02',
    title: 'Landing Pages',
    description:
      'Single-page sites built around one goal: getting people to book, sign up, or buy. Great for promotions, new services, or testing an idea.',
    color: 'orange',
  },
  {
    icon: '03',
    title: 'Website Redesign',
    description:
      "If your current site looks like it's from 2015, I can help. I'll rebuild it with a modern design, better performance, and a layout that actually works for your customers.",
    color: 'magenta',
  },
  {
    icon: '04',
    title: 'Ongoing Support',
    description:
      'Need something updated? Have a question about your site? I stick around after launch. You get a real person to call, not a support ticket.',
    color: 'purple',
  },
];

const whyPoints = [
  {
    title: '14+ years of experience',
    description:
      "I've been building for the web since 2012, at startups and large companies. I've seen what works and what doesn't.",
  },
  {
    title: 'Local to Denver & Lakewood',
    description:
      "I live in the area and I'm happy to meet in person. I know the Front Range market and what local businesses are looking for.",
  },
  {
    title: 'One developer, no middlemen',
    description:
      "You talk directly to the person building your site. No project managers, no game of telephone. Just straightforward communication.",
  },
  {
    title: 'Modern tech, fast sites',
    description:
      'I use current tools and frameworks so your site loads quickly, works on every device, and shows up in search results.',
  },
];

const steps = [
  {
    number: '01',
    title: 'Chat',
    description:
      "We grab coffee or hop on a call. I'll ask about your business, what you need, and what a good outcome looks like for you.",
  },
  {
    number: '02',
    title: 'Build',
    description:
      "I design and build your site, and check in with you along the way. No big reveal at the end where it's nothing like what you wanted.",
  },
  {
    number: '03',
    title: 'Launch',
    description:
      "Your site goes live. I make sure everything's working and walk you through how to keep it updated.",
  },
];

const faqs = [
  {
    question: 'How much does a website cost for a small business in Denver?',
    answer:
      "It depends on the project, but most small business sites I build land between $2,000 and $8,000. Landing pages are on the lower end, and bigger sites with custom features cost more. I'll give you a straightforward estimate after we talk. No hidden fees.",
  },
  {
    question: 'How long does it take to build a website?',
    answer:
      'Usually 3 to 6 weeks from start to launch. A simple landing page might only take a week or two. Larger projects can take longer, but I keep you in the loop the whole time.',
  },
  {
    question: 'Do you work with businesses outside Denver and Lakewood?',
    answer:
      "For sure. I'm based in the Denver/Lakewood area, but I work with businesses all over the Front Range: Golden, Arvada, Wheat Ridge, Englewood, Aurora, Centennial, Highlands Ranch, Westminster, Broomfield, Thornton, Boulder, and beyond. Remote works great too.",
  },
  {
    question: 'Will my website work well on mobile?',
    answer:
      "Yes. I build mobile-first, meaning the phone experience comes first, not as an afterthought. Over 60% of web traffic comes from phones, so your site needs to look good and load fast on smaller screens. I test on real devices.",
  },
  {
    question: 'Can you help my business rank on Google?',
    answer:
      "I bake SEO basics into every site: clean heading structure, meta tags, fast load times, mobile optimization, and structured data. For local businesses, I also handle Google Business Profile integration and local schema markup so you can show up in map results.",
  },
  {
    question: "What's the difference between a template website and a custom-built one?",
    answer:
      "Template sites (Wix, Squarespace, WordPress themes) give you a pre-made layout that you fill in. They work for some businesses, but they're limited in speed, SEO, and design flexibility. A custom-built site is coded specifically for your business, loads faster, ranks better, and can do exactly what you need without fighting a template's limitations.",
  },
  {
    question: 'Do I need to provide content and photos for my website?',
    answer:
      "It helps if you have some photos of your business, team, or products, but I can work with what you've got. I'll write the website copy with you or for you based on our conversations. I know what works for web content and can help shape your message.",
  },
  {
    question: 'What happens after my website launches? Do you offer maintenance?',
    answer:
      "Yes. I offer ongoing support plans for updates, changes, and maintenance. But even without a support plan, I don't disappear after launch. If something breaks or you have a quick question, I'm a text or email away.",
  },
  {
    question: 'Can you help with Google Business Profile setup?',
    answer:
      "Absolutely. For local businesses, your Google Business Profile is as important as your website. I'll help you set it up or optimize your existing one, connect it to your site, and make sure your business info is consistent across the web.",
  },
  {
    question: 'How do I know if my business needs a new website?',
    answer:
      "If your site is slow, doesn't look good on phones, hasn't been updated in a few years, or you're embarrassed to share the link, it's probably time. I offer a free consultation where I'll take a look at your current site and give you an honest assessment.",
  },
];

const jsonLdService = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Bill Bergquist — Web Development Services',
  description:
    'Professional web design and development services for small businesses in Denver, Lakewood, and the Colorado Front Range.',
  url: 'https://billbergquist.dev/services',
  email: 'services@billbergquist.dev',
  areaServed: [
    { '@type': 'City', name: 'Denver', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Lakewood', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Golden', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Arvada', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Wheat Ridge', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Littleton', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Englewood', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Aurora', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Centennial', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Highlands Ranch', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Westminster', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Broomfield', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Thornton', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Boulder', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Parker', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Castle Rock', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Edgewater', containedInPlace: { '@type': 'State', name: 'Colorado' } },
    { '@type': 'City', name: 'Commerce City', containedInPlace: { '@type': 'State', name: 'Colorado' } },
  ],
  provider: {
    '@type': 'Person',
    name: 'Bill Bergquist',
    jobTitle: 'Staff Software Engineer',
    url: 'https://billbergquist.dev',
  },
  serviceType: ['Web Design', 'Web Development', 'Website Redesign', 'Landing Page Design'],
  priceRange: '$$',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web Development Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Business Websites',
          description:
            'Professional websites for small businesses in Denver and the Colorado Front Range. Fast, mobile-friendly, and built to convert.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Landing Pages',
          description:
            'Focused, single-page sites designed to drive bookings, signups, or sales for Colorado businesses.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Website Redesign',
          description:
            'Modernize your outdated website with a fresh design, faster performance, and better user experience.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Ongoing Support & Maintenance',
          description:
            'Website updates, tweaks, and maintenance from a local developer you can reach out to anytime.',
        },
      },
    ],
  },
});

const jsonLdFaq = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
});
---

<Layout
  title="Web Design Services in Denver & Lakewood, CO — Bill Bergquist"
  description="Web design and development for small businesses in Denver, Lakewood, and the Colorado Front Range. Built by a local staff engineer with 14+ years of experience."
  canonical="/services"
  jsonLd={[jsonLdService, jsonLdFaq]}
  ogImage="/og/services.png"
  geoRegion="US-CO"
  geoPlacename="Denver, CO"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <GlowText as="h1" size="large" color="mint" class={styles.title}>
        WEB DESIGN & DEVELOPMENT IN DENVER
      </GlowText>
      <p class={styles.subtitle}>Denver &middot; Lakewood &middot; Front Range &middot; Colorado</p>
      <p class={styles.intro}>
        I'm a staff software engineer with over 14 years of experience building for the web. I help
        small businesses across Denver, Lakewood, and the Colorado Front Range get online with fast,
        modern websites that look great and actually work.
      </p>
      <div class="accent-line-orange"></div>
    </header>

    <section class={`${styles.services} scroll-reveal`}>
      <GlowText as="h2" size="medium" color="orange" class={styles.sectionTitle}>
        WHAT I OFFER
      </GlowText>
      <div class={styles.serviceGrid}>
        {
          services.map((service) => (
            <div class="scroll-reveal-child">
              <Card class={styles.serviceCard}>
                <span class={`${styles.serviceIcon} ${styles[`color_${service.color}`]}`}>
                  {service.icon}
                </span>
                <h3 class={`${styles.serviceTitle} ${styles[`color_${service.color}`]}`}>
                  {service.title}
                </h3>
                <p class={styles.serviceDescription}>{service.description}</p>
              </Card>
            </div>
          ))
        }
      </div>
    </section>

    <SectionDivider color="mint" />

    <RecentWork />

    <SectionDivider color="purple" />

    <section class={`${styles.whySection} scroll-reveal`}>
      <GlowText as="h2" size="medium" color="purple" class={styles.sectionTitle}>
        WHY WORK WITH A LOCAL DEVELOPER
      </GlowText>
      <Image
        src={headshot}
        alt="Bill Bergquist — web developer in Denver, CO"
        width={150}
        height={150}
        class={styles.headshot}
        loading="lazy"
      />
      <div class={styles.whyGrid}>
        {
          whyPoints.map((point) => (
            <div class={`${styles.whyItem} scroll-reveal-child`}>
              <h3 class={styles.whyTitle}>{point.title}</h3>
              <p class={styles.whyDescription}>{point.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <CredibilitySection />

    <SectionDivider color="orange" />

    <section class={`${styles.process} scroll-reveal`}>
      <GlowText as="h2" size="medium" color="magenta" class={styles.sectionTitle}>
        HOW IT WORKS
      </GlowText>
      <div class={styles.steps}>
        {
          steps.map((step, i) => (
            <div class={`${styles.step} scroll-reveal-child`}>
              <div class={styles.stepConnector}>
                <span class={styles.stepNumber}>{step.number}</span>
                {i < steps.length - 1 && <div class={styles.stepLine} />}
              </div>
              <div class={styles.stepContent}>
                <h3 class={styles.stepTitle}>{step.title}</h3>
                <p class={styles.stepDescription}>{step.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <SectionDivider color="purple" />

    <section class={`${styles.faq} scroll-reveal`}>
      <GlowText as="h2" size="medium" color="orange" class={styles.sectionTitle}>
        FREQUENTLY ASKED QUESTIONS
      </GlowText>
      <div class={styles.faqList}>
        {
          faqs.map((faq) => (
            <div class={`${styles.faqItem} scroll-reveal-child`}>
              <h3 class={styles.faqQuestion}>{faq.question}</h3>
              <p class={styles.faqAnswer}>{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </section>

    <SectionDivider color="purple" />

    <section class={`${styles.areasServed} scroll-reveal`}>
      <GlowText as="h2" size="medium" color="purple" class={styles.sectionTitle}>
        AREAS I SERVE
      </GlowText>
      <div class={styles.areasGrid}>
        <a href="/services/denver" class={styles.areaLink}>Denver</a>
        <a href="/services/lakewood" class={styles.areaLink}>Lakewood</a>
        <a href="/services/boulder" class={styles.areaLink}>Boulder</a>
        <span class={styles.areaText}>Golden</span>
        <span class={styles.areaText}>Arvada</span>
        <span class={styles.areaText}>Wheat Ridge</span>
        <span class={styles.areaText}>Littleton</span>
        <span class={styles.areaText}>Englewood</span>
        <span class={styles.areaText}>Aurora</span>
        <span class={styles.areaText}>Centennial</span>
        <span class={styles.areaText}>Highlands Ranch</span>
        <span class={styles.areaText}>Westminster</span>
        <span class={styles.areaText}>Broomfield</span>
        <span class={styles.areaText}>Thornton</span>
        <span class={styles.areaText}>Edgewater</span>
      </div>
      <p class={styles.areasNote}>
        I also work with businesses anywhere in Colorado and beyond. Remote collaboration works great.
      </p>
    </section>

    <SectionDivider color="mint" />

    <section class={`${styles.contact} scroll-reveal`}>
      <GlowText as="h2" size="medium" color="mint" class={styles.sectionTitle}>
        GET IN TOUCH
      </GlowText>
      <p class={styles.contactIntro}>
        Have a project in mind? Whether you run a coffee shop in Denver, a boutique in Lakewood, a
        restaurant in Arvada, or any other Front Range business, I'd love to hear about it.
      </p>

      <div class={styles.trustSignals}>
        <span class={styles.trustItem}>&#10003; Currently booking for {bookingMonth}</span>
        <span class={styles.trustItem}>&#10003; Free consultation, no obligation</span>
        <span class={styles.trustItem}>&#10003; Response within 1 business day</span>
        <a href="https://share.google/AN9wq1GbXPqjeQwEf" target="_blank" rel="noopener noreferrer" class={styles.trustItem}>
          &#10003; View my Google Business Profile
        </a>
      </div>

      <ContactForm client:visible />

      <div class={styles.emailAlt}>
        <p>
          Prefer email?{' '}
          <a href="mailto:services@billbergquist.dev" class={styles.emailLink}>
            services@billbergquist.dev
          </a>
        </p>
      </div>
    </section>

    <section class={`${styles.techStrip} scroll-reveal`}>
      <p class={styles.techStripLabel}>Built with modern tools</p>
      <div class={styles.techStripList}>
        <span class={styles.techStripItem}>Astro</span>
        <span class={styles.techStripItem}>React</span>
        <span class={styles.techStripItem}>TypeScript</span>
        <span class={styles.techStripItem}>Netlify</span>
        <span class={styles.techStripItem}>Tailwind CSS</span>
      </div>
    </section>
  </div>
</Layout>
