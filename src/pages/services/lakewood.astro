---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/services/ContactForm';
import styles from '../ServicesPage.module.css';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const faqs = [
  {
    question: 'People always search for Denver businesses instead of Lakewood. Can a website fix that?',
    answer:
      "This is the #1 problem Lakewood businesses face online. When someone on the west side searches for a plumber or a restaurant, Google often serves Denver results first. A custom website with Lakewood-specific content, local schema markup, and proper geo-targeting tells Google your business is in Lakewood and should show up for Lakewood searches. It won't happen overnight, but the right technical foundation makes a real difference over time.",
  },
  {
    question: 'I run a home services business out of Lakewood. What kind of website do I need?',
    answer:
      "Home services businesses (plumbers, HVAC, electricians, landscapers) need a few specific things: clear service area information so customers know you cover their neighborhood, a fast-loading site because people searching for emergency services won't wait, easy-to-find phone numbers and contact forms, and photos of real work you've done. I also set up your site to target the specific zip codes and neighborhoods you serve so you're not getting calls from areas you don't cover.",
  },
  {
    question: 'What makes Belmar and Wadsworth businesses different from downtown Denver in terms of web presence?',
    answer:
      "The customer mindset is different. People shopping at Belmar or along Wadsworth are usually Lakewood residents looking for something close to home, not tourists or commuters. Your website should speak to that local, community-oriented audience. That means emphasizing convenience, local roots, and neighborhood familiarity rather than trying to compete with flashy downtown Denver businesses. The content strategy and keywords are completely different.",
  },
  {
    question: 'My business has been doing fine without a website. Why would I need one now?',
    answer:
      "If you're getting enough business from word of mouth, that's great. But consider what happens when someone gets a referral and then Googles you. If they find nothing, or they find a bare Facebook page, some of those referrals are going to a competitor who does have a professional site. A website doesn't replace word of mouth. It reinforces it. It's the thing that makes people feel confident enough to call after a friend mentioned your name.",
  },
  {
    question: 'How long does it take to get a Lakewood business website up and running?',
    answer:
      "Most projects go from first conversation to live site in 3 to 6 weeks. A simple landing page can be done in a week or two. Bigger sites with custom features take longer, but I keep you in the loop the whole time with regular check-ins. I don't disappear for a month and then show you something you didn't ask for.",
  },
];

const jsonLdService = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Bill Bergquist — Web Design in Lakewood, CO',
  description:
    'Custom web design and development for small businesses in Lakewood, Colorado. Fast, modern websites built by a local developer.',
  url: 'https://billbergquist.dev/services/lakewood/',
  email: 'services@billbergquist.dev',
  telephone: '+1-847-280-0729',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Lakewood',
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: 'Lakewood',
    containedInPlace: { '@type': 'State', name: 'Colorado' },
  },
  provider: {
    '@id': 'https://billbergquist.dev/#person',
  },
  serviceType: ['Web Design', 'Web Development', 'Website Redesign', 'Landing Page Design'],
  priceRange: '$$',
  image: 'https://billbergquist.dev/og/services-lakewood.png',
  dateModified: '2026-03-09',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web Development Services in Lakewood',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Business Websites',
          description: 'Professional websites for Lakewood small businesses. Fast, mobile-friendly, and built to convert.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Landing Pages',
          description: 'Focused, single-page sites designed to drive bookings, signups, or sales for Lakewood businesses.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Website Redesign',
          description: 'Modernize your outdated website with a fresh design, faster performance, and better user experience.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Ongoing Support & Maintenance',
          description: 'Website updates, tweaks, and maintenance from a local Lakewood developer you can reach out to anytime.',
        },
      },
    ],
  },
});

const jsonLdFaq = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
});

const bookingMonth = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toLocaleString('en-US', {
  month: 'long',
});
---

<Layout
  title="Web Design in Lakewood, CO — Bill Bergquist"
  description="Custom web design for Lakewood small businesses. Fast, mobile-friendly websites built by a local developer who lives in the Lakewood area."
  canonical="/services/lakewood"
  jsonLd={[jsonLdService, jsonLdFaq]}
  ogImage="/og/services-lakewood.png"
  geoRegion="US-CO"
  geoPlacename="Lakewood, CO"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <h1 class={styles.title}>
        Web Design in Lakewood, CO
      </h1>
      <p class={styles.subtitle}>Custom Websites for Lakewood Small Businesses</p>
      <p class={styles.intro}>
        Lakewood has its own identity. It's not just a Denver suburb. From the shops and restaurants
        along Wadsworth Boulevard to the boutiques at Belmar, the breweries in the Green Mountain area,
        and the home services businesses that serve the whole west side, Lakewood businesses need websites
        that reflect who they are and reach the customers searching for them.
      </p>
    </header>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Why Lakewood Businesses Need a Strong Web Presence
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Lakewood isn't just "west Denver"</h3>
          <p class={styles.whyDescription}>
            People search for "restaurants in Lakewood" and "plumber near Belmar," not just "Denver."
            A website optimized for Lakewood-specific searches helps you capture customers who are
            specifically looking for local businesses, not results 20 miles away in Aurora or Thornton.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>West side customers search differently</h3>
          <p class={styles.whyDescription}>
            Lakewood residents tend to stay on the west side. They search for services near Green Mountain,
            near Belmar, along Colfax, or on Wadsworth. A well-built website with local SEO captures these
            neighborhood-level searches that a generic site misses.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Compete with Denver agencies for less</h3>
          <p class={styles.whyDescription}>
            Denver agencies charge $10,000-$25,000+ for a small business site. As a local independent
            developer, I deliver the same quality at a fraction of the cost, and you work directly with
            the person building your site, not an account manager.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>I live here</h3>
          <p class={styles.whyDescription}>
            I'm based in the Lakewood area. I shop at the same stores and eat at the same restaurants.
            I get what makes a Lakewood business different from one downtown, and I can build a site
            that reflects that.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Lakewood Businesses I Work With
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Home services</h3>
          <p class={styles.whyDescription}>
            Plumbers, HVAC techs, electricians, landscapers, roofers. Lakewood's residential
            neighborhoods keep home services businesses busy, and a fast website with clear service
            areas, pricing, and easy contact options means more calls from homeowners in your
            actual coverage area.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Restaurants & breweries</h3>
          <p class={styles.whyDescription}>
            From Belmar dining to Wadsworth corridor restaurants to the growing craft brewery scene,
            Lakewood's food and drink options are better than people think. I build sites with menus,
            hours, and the local SEO that helps you compete with Denver restaurants for search traffic.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Retail & shopping</h3>
          <p class={styles.whyDescription}>
            Belmar boutiques, specialty shops along Wadsworth, stores near Colorado Mills. Lakewood
            has a strong retail community that benefits from websites with product showcases, store
            hours, and e-commerce for reaching customers beyond foot traffic.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Professional services</h3>
          <p class={styles.whyDescription}>
            Accountants, insurance agents, real estate offices, consultants. Lakewood's business
            parks and the Federal Center area house plenty of professional services that need
            clean, credible websites to attract clients from across the west metro.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.faq}>
      <h2 class={styles.sectionTitle}>
        Frequently Asked Questions
      </h2>
      <FaqAccordion faqs={faqs} />
    </section>

    <p class={styles.perfLink}>
      Want a quick ballpark? <a href="/services/estimate/">Try the cost calculator &rarr;</a>
    </p>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>Related Reading</h2>
      <div class={styles.faqList}>
        <div class={styles.faqItem}>
          <a href="/blog/how-much-does-a-website-cost-denver/">How Much Does a Website Cost in Denver?</a>
          <p class={styles.faqAnswer}>Pricing applies across the metro area. A detailed breakdown of what Lakewood businesses can expect to pay.</p>
        </div>
        <div class={styles.faqItem}>
          <a href="/blog/signs-your-business-website-needs-redesign/">Signs Your Business Website Needs a Redesign</a>
          <p class={styles.faqAnswer}>Not sure if your current site is holding you back? Here are the telltale signs.</p>
        </div>
        <div class={styles.faqItem}>
          <a href="/blog/template-vs-custom-website/">Template vs. Custom Website: Which Is Right for Your Business?</a>
          <p class={styles.faqAnswer}>Understand the trade-offs before deciding how to build your next site.</p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.areasServed}>
      <h2 class={styles.sectionTitle}>
        Also Serving Nearby
      </h2>
      <div class={styles.areasGrid}>
        <a href="/services/denver/" class={styles.areaLink}>Denver</a>
        <a href="/services/golden/" class={styles.areaLink}>Golden</a>
        <a href="/services/arvada/" class={styles.areaLink}>Arvada</a>
        <a href="/services/littleton/" class={styles.areaLink}>Littleton</a>
        <a href="/services/highlands-ranch/" class={styles.areaLink}>Highlands Ranch</a>
        <a href="/services/boulder/" class={styles.areaLink}>Boulder</a>
        <span class={styles.areaText}>Wheat Ridge</span>
        <span class={styles.areaText}>Edgewater</span>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.contact}>
      <h2 class={styles.sectionTitle}>
        Let's Build Your Lakewood Website
      </h2>
      <p class={styles.contactIntro}>
        Whether you run a boutique in Belmar, a restaurant on Wadsworth, a home services company
        serving the west side, or any other Lakewood business, I'd love to hear about your project.
      </p>

      <div class={styles.trustSignals}>
        <span class={styles.trustItem}>&#10003; Currently booking for {bookingMonth}</span>
        <span class={styles.trustItem}>&#10003; Free consultation, no obligation</span>
        <span class={styles.trustItem}>&#10003; Response within 1 business day</span>
        <a href="https://share.google/AN9wq1GbXPqjeQwEf" target="_blank" rel="noopener noreferrer" class={styles.trustItem}>
          &#10003; View my Google Business Profile
        </a>
      </div>

      <ContactForm client:visible />

      <div class={styles.emailAlt}>
        <p>
          Prefer to reach out directly?{' '}
          <a href="tel:+18472800729" class={styles.emailLink}>(847) 280-0729</a>{' '}
          or{' '}
          <a href="mailto:services@billbergquist.dev" class={styles.emailLink}>
            services@billbergquist.dev
          </a>
        </p>
        <p style="margin-top: var(--space-md);">
          <a href="/services/" class={styles.emailLink}>&larr; Back to all services</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
