---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/services/ContactForm';
import styles from '../ServicesPage.module.css';

const faqs = [
  {
    question: 'How much does a website cost for an Arvada business?',
    answer:
      "Most small business sites I build run between $2,000 and $8,000. A simple landing page costs less, while a full site with custom features or e-commerce runs higher. I'll give you a clear number after we talk about your project.",
  },
  {
    question: 'Can you help my Olde Town Arvada business stand out online?',
    answer:
      "Absolutely. Olde Town businesses have a unique character that deserves a website to match. I build sites that capture the feel of your brick-and-mortar space and help you show up when people search for businesses in the Olde Town area.",
  },
  {
    question: 'Do you help with Google Maps and local search for Arvada?',
    answer:
      "Yes. Local search is critical for Arvada businesses, especially with Denver right next door pulling search traffic. I set up local schema markup, optimize your Google Business Profile connection, and make sure your site targets Arvada-specific searches so you show up for customers in your area.",
  },
];

const jsonLdService = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Bill Bergquist — Web Design in Arvada, CO',
  description:
    'Custom web design and development for small businesses in Arvada, Colorado. Fast, modern websites built by a local Front Range developer.',
  url: 'https://billbergquist.dev/services/arvada',
  email: 'services@billbergquist.dev',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Arvada',
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: 'Arvada',
    containedInPlace: { '@type': 'State', name: 'Colorado' },
  },
  provider: {
    '@id': 'https://billbergquist.dev/#person',
  },
  serviceType: ['Web Design', 'Web Development', 'Website Redesign', 'Landing Page Design'],
  priceRange: '$$',
  image: 'https://billbergquist.dev/og/services-arvada.png',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web Development Services in Arvada',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Business Websites',
          description: 'Professional websites for Arvada small businesses. Fast, mobile-friendly, and built to convert.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Landing Pages',
          description: 'Focused, single-page sites designed to drive bookings, signups, or sales for Arvada businesses.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Website Redesign',
          description: 'Modernize your outdated website with a fresh design, faster performance, and better user experience.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Ongoing Support & Maintenance',
          description: 'Website updates, tweaks, and maintenance from a local Front Range developer you can reach out to anytime.',
        },
      },
    ],
  },
});

const jsonLdFaq = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
});

const bookingMonth = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toLocaleString('en-US', {
  month: 'long',
});
---

<Layout
  title="Web Design in Arvada, CO — Bill Bergquist"
  description="Custom web design for Arvada small businesses. Fast, modern websites built by a local developer. From Olde Town shops to Ralston Creek restaurants."
  canonical="/services/arvada"
  jsonLd={[jsonLdService, jsonLdFaq]}
  ogImage="/og/services-arvada.png"
  geoRegion="US-CO"
  geoPlacename="Arvada, CO"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <h1 class={styles.title}>
        Web Design in Arvada, CO
      </h1>
      <p class={styles.subtitle}>Custom Websites for Arvada Small Businesses</p>
      <p class={styles.intro}>
        Arvada has changed a lot over the past decade, but the one thing that hasn't changed is the
        strength of its local business community. From the restaurants and shops lining Olde Town to the
        home services companies serving neighborhoods from Ralston Creek to Leyden Rock, Arvada businesses
        need websites that reflect the quality of what they do. I build fast, custom websites that help
        Arvada businesses get found online and win more customers.
      </p>
    </header>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Why Arvada Businesses Invest in Custom Websites
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Olde Town draws foot traffic and search traffic</h3>
          <p class={styles.whyDescription}>
            Olde Town Arvada is one of the best walkable districts on the Front Range. People search
            for "restaurants in Olde Town Arvada" and "shops near Olde Town" before they visit. If your
            website isn't showing up for those searches, you're leaving customers to your neighbors.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Don't get buried under Denver results</h3>
          <p class={styles.whyDescription}>
            Arvada sits between Denver and Golden, which means your business competes with a lot of
            search results. A website with strong local SEO helps you rank for Arvada-specific searches
            instead of getting lost in a sea of Denver results.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>A growing city needs a modern web presence</h3>
          <p class={styles.whyDescription}>
            Arvada's population has grown significantly, with new neighborhoods and developments
            bringing in residents who search online first. New residents don't have a go-to plumber
            or dentist yet. They're Googling. Your website is your first impression.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Local developer, not a faceless agency</h3>
          <p class={styles.whyDescription}>
            I'm based in the Lakewood/Denver metro area, minutes from Arvada. I can meet you at your
            business or grab coffee in Olde Town. You work directly with me, not an account manager
            who's never set foot in Jefferson County.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Arvada Businesses I Work With
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Restaurants & breweries</h3>
          <p class={styles.whyDescription}>
            Arvada's food and drink scene has exploded. Whether you're a restaurant in Olde Town,
            a brewery near Ralston Road, or a new cafe on Wadsworth, I build sites with menus,
            hours, reservations, and the local SEO that gets you found by hungry customers.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Retail & boutique shops</h3>
          <p class={styles.whyDescription}>
            Olde Town's independent shops compete with big box stores and Amazon. A well-built
            website with product showcases, store hours, and e-commerce capabilities helps you
            reach customers before they default to a chain.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Home services</h3>
          <p class={styles.whyDescription}>
            Plumbers, electricians, HVAC techs, landscapers. Arvada homeowners search for these
            services constantly. A fast website with clear service areas, pricing info, and easy
            contact options means more calls from your actual service area.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Health & wellness</h3>
          <p class={styles.whyDescription}>
            Dental offices, chiropractors, yoga studios, personal trainers. Arvada residents want
            providers close to home. A professional site with online booking, service descriptions,
            and patient/client reviews builds trust before they ever walk in.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.faq}>
      <h2 class={styles.sectionTitle}>
        Frequently Asked Questions
      </h2>
      <div class={styles.faqList}>
        {
          faqs.map((faq) => (
            <div class={styles.faqItem}>
              <h3 class={styles.faqQuestion}>{faq.question}</h3>
              <p class={styles.faqAnswer}>{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.areasServed}>
      <h2 class={styles.sectionTitle}>
        Also Serving Nearby
      </h2>
      <div class={styles.areasGrid}>
        <a href="/services/denver/" class={styles.areaLink}>Denver</a>
        <a href="/services/lakewood/" class={styles.areaLink}>Lakewood</a>
        <a href="/services/golden/" class={styles.areaLink}>Golden</a>
        <a href="/services/boulder/" class={styles.areaLink}>Boulder</a>
        <a href="/services/littleton/" class={styles.areaLink}>Littleton</a>
        <span class={styles.areaText}>Wheat Ridge</span>
        <span class={styles.areaText}>Westminster</span>
        <span class={styles.areaText}>Broomfield</span>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.contact}>
      <h2 class={styles.sectionTitle}>
        Let's Build Your Arvada Website
      </h2>
      <p class={styles.contactIntro}>
        Whether you run a shop in Olde Town, a restaurant near Ralston Creek, a home services
        company covering the west side, or any other Arvada business, I'd love to hear about your project.
      </p>

      <div class={styles.trustSignals}>
        <span class={styles.trustItem}>&#10003; Currently booking for {bookingMonth}</span>
        <span class={styles.trustItem}>&#10003; Free consultation, no obligation</span>
        <span class={styles.trustItem}>&#10003; Response within 1 business day</span>
      </div>

      <ContactForm client:visible />

      <div class={styles.emailAlt}>
        <p>
          Prefer email?{' '}
          <a href="mailto:services@billbergquist.dev" class={styles.emailLink}>
            services@billbergquist.dev
          </a>
        </p>
        <p style="margin-top: var(--space-md);">
          <a href="/services/" class={styles.emailLink}>&larr; Back to all services</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
