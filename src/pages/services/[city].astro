---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/services/ContactForm';
import styles from '../ServicesPage.module.css';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';
import { serviceCities } from '../../data/service-cities';
import { BASE_URL, CONTACT_EMAIL, CONTACT_PHONE, CONTACT_PHONE_DISPLAY, CONTACT_PHONE_TEL, GBP_URL, PERSON_REF } from '../../shared/site';
import { getBookingMonth } from '../../shared/utils/content';

import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return serviceCities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
};

const { city } = Astro.props;

const jsonLdService = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: `Bill Bergquist — Web Design in ${city.name}, CO`,
  description: city.meta.schemaDescription,
  url: `${BASE_URL}/services/${city.slug}/`,
  email: CONTACT_EMAIL,
  telephone: CONTACT_PHONE,
  address: {
    '@type': 'PostalAddress',
    addressLocality: city.name,
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: city.name,
    containedInPlace: { '@type': 'State', name: 'Colorado' },
  },
  provider: PERSON_REF,
  serviceType: ['Web Design', 'Web Development', 'Website Redesign', 'Landing Page Design'],
  priceRange: '$$',
  image: `${BASE_URL}${city.meta.ogImage}`,
  dateModified: '2026-03-09',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `Web Development Services in ${city.name}`,
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Business Websites',
          description: `Professional websites for ${city.name} small businesses. Fast, mobile-friendly, and built to convert.`,
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Landing Pages',
          description: `Focused, single-page sites designed to drive bookings, signups, or sales for ${city.name} businesses.`,
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Website Redesign',
          description: 'Modernize your outdated website with a fresh design, faster performance, and better user experience.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Ongoing Support & Maintenance',
          description: city.meta.maintenanceDescription,
        },
      },
    ],
  },
});

const jsonLdFaq = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: city.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
});

const bookingMonth = getBookingMonth();
---

<Layout
  title={city.meta.title}
  description={city.meta.description}
  canonical={`/services/${city.slug}`}
  jsonLd={[jsonLdService, jsonLdFaq]}
  ogImage={city.meta.ogImage}
  geoRegion="US-CO"
  geoPlacename={`${city.name}, CO`}
>
  <div class={styles.page}>
    <header class={styles.header}>
      <h1 class={styles.title}>
        Web Design in {city.name}, CO
      </h1>
      <p class={styles.subtitle}>Custom Websites for {city.name} Small Businesses</p>
      <p class={styles.intro}>
        {city.intro}
      </p>
    </header>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        {city.whyTitle}
      </h2>
      <div class={styles.whyGrid}>
        {city.whyItems.map((item) => (
          <div class={styles.whyItem}>
            <h3 class={styles.whyTitle}>{item.title}</h3>
            <p class={styles.whyDescription}>{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        {city.businessesTitle}
      </h2>
      <div class={styles.whyGrid}>
        {city.businessItems.map((item) => (
          <div class={styles.whyItem}>
            <h3 class={styles.whyTitle}>{item.title}</h3>
            <p class={styles.whyDescription}>{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.faq}>
      <h2 class={styles.sectionTitle}>
        Frequently Asked Questions
      </h2>
      <FaqAccordion faqs={city.faqs} />
    </section>

    <p class={styles.perfLink}>
      Want a quick ballpark? <a href="/services/estimate/">Try the cost calculator &rarr;</a>
    </p>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>Related Reading</h2>
      <div class={styles.faqList}>
        {city.relatedLinks.map((link) => (
          <div class={styles.faqItem}>
            <a href={link.href}>{link.title}</a>
            <p class={styles.faqAnswer}>{link.description}</p>
          </div>
        ))}
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.areasServed}>
      <h2 class={styles.sectionTitle}>
        Also Serving Nearby
      </h2>
      <div class={styles.areasGrid}>
        {city.nearbyLinks.map((link) =>
          link.href ? (
            <a href={link.href} class={styles.areaLink}>{link.label}</a>
          ) : (
            <span class={styles.areaText}>{link.label}</span>
          )
        )}
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.contact}>
      <h2 class={styles.sectionTitle}>
        {city.contactTitle}
      </h2>
      <p class={styles.contactIntro}>
        {city.contactIntro}
      </p>

      <div class={styles.trustSignals}>
        <span class={styles.trustItem}>&#10003; Currently booking for {bookingMonth}</span>
        <span class={styles.trustItem}>&#10003; Free consultation, no obligation</span>
        <span class={styles.trustItem}>&#10003; Response within 1 business day</span>
        <a href={GBP_URL} target="_blank" rel="noopener noreferrer" class={styles.trustItem}>
          &#10003; View my Google Business Profile
        </a>
      </div>

      <ContactForm client:visible />

      <div class={styles.emailAlt}>
        <p>
          Prefer to reach out directly?{' '}
          <a href={`tel:${CONTACT_PHONE_TEL}`} class={styles.emailLink}>{CONTACT_PHONE_DISPLAY}</a>{' '}
          or{' '}
          <a href={`mailto:${CONTACT_EMAIL}`} class={styles.emailLink}>
            {CONTACT_EMAIL}
          </a>
        </p>
        <p style="margin-top: var(--space-md);">
          <a href="/services/" class={styles.emailLink}>&larr; Back to all services</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
