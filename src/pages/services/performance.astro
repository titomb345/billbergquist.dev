---
import Layout from '../../layouts/Layout.astro';
import PerformanceCompare from '../../components/services/PerformanceCompare';
import styles from '../PerformancePage.module.css';

const PSI_API_KEY = import.meta.env.PUBLIC_PSI_API_KEY || '';

const sites = [
  {
    name: 'This Site',
    url: 'billbergquist.dev',
    scores: { performance: 99, accessibility: 100, bestPractices: 100, seo: 100 },
  },
  {
    name: 'Critter Care',
    url: 'critter-care.com',
    scores: { performance: 100, accessibility: 100, bestPractices: 100, seo: 100 },
  },
  {
    name: 'CreatiCalc',
    url: 'creaticalc.com',
    scores: { performance: 99, accessibility: 100, bestPractices: 100, seo: 100 },
  },
];

function avg(key: keyof (typeof sites)[0]['scores']) {
  return Math.round(sites.reduce((sum, s) => sum + s.scores[key], 0) / sites.length);
}

const portfolioAvg = {
  performance: avg('performance'),
  accessibility: avg('accessibility'),
  bestPractices: avg('bestPractices'),
  seo: avg('seo'),
};

function scoreColor(score: number): string {
  if (score >= 90) return '#0cce6b';
  if (score >= 50) return '#ffa400';
  return '#ff4e42';
}

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Site Performance — Bill Bergquist',
  description:
    'Real Lighthouse performance scores for websites built by Bill Bergquist. Test your own site and compare.',
  url: 'https://billbergquist.dev/services/performance/',
  author: { '@id': 'https://billbergquist.dev/#person' },
});
---

<Layout
  title="Site Performance — Bill Bergquist"
  description="Real Lighthouse scores for websites I've built. See how billbergquist.dev, critter-care.com, and creaticalc.com perform, then test your own site."
  canonical="/services/performance"
  jsonLd={[jsonLd]}
>
  <div class={styles.page}>
    <header class={styles.header}>
      <p class={styles.eyebrow}>Most small business sites score 40 to 60 on Google's performance audit.</p>
      <h1 class={styles.title}>Mine Score 95+.</h1>
      <p class={styles.subtitle}>
        Real results from Google's own auditing tool, not cherry-picked screenshots.
      </p>
    </header>

    <section>
      <h2 class={styles.sectionTitle}>Portfolio Scores</h2>
      <p class={styles.sectionSubtitle}>
        Each score is from a Google Lighthouse audit run on mobile. Scores range from 0 to 100.
      </p>

      <div class={styles.sitesGrid}>
        {
          sites.map((site) => (
            <div class={styles.siteCard}>
              <h3 class={styles.siteName}>{site.name}</h3>
              <a href={`https://${site.url}`} target="_blank" rel="noopener noreferrer" class={styles.siteUrl}>{site.url}</a>
              <div class={styles.scoresGrid}>
                {(
                  [
                    { key: 'performance', label: 'Perf' },
                    { key: 'accessibility', label: 'A11y' },
                    { key: 'bestPractices', label: 'BP' },
                    { key: 'seo', label: 'SEO' },
                  ] as const
                ).map((cat) => (
                  <div class={styles.scoreItem}>
                    <div
                      class={styles.scoreRing}
                      style={`--ring-color: ${scoreColor(site.scores[cat.key])}; --score: ${site.scores[cat.key]};`}
                    >
                      <span class={styles.scoreValue}>{site.scores[cat.key]}</span>
                    </div>
                    <span class={styles.scoreLabel}>{cat.label}</span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <p class={styles.scoreDate}>Scores recorded March 2026</p>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.compareSection}>
      <PerformanceCompare client:visible portfolioAvg={portfolioAvg} apiKey={PSI_API_KEY} />
    </section>

    <div class={styles.divider}></div>

    <section class={styles.methodology}>
      <h2 class={styles.sectionTitle}>How I Measure</h2>
      <p class={styles.methodologyText}>
        All scores come from{' '}
        <a
          href="https://developer.chrome.com/docs/lighthouse/overview"
          target="_blank"
          rel="noopener noreferrer"
        >Google Lighthouse</a>, the industry standard for web performance auditing and the same
        tool Google uses to evaluate sites for search ranking. You can verify these scores yourself
        using the "Test Your Site" tool above or by visiting{' '}
        <a
          href="https://pagespeed.web.dev/"
          target="_blank"
          rel="noopener noreferrer"
        >pagespeed.web.dev</a> directly.
      </p>

      <div class={styles.methodologyGrid}>
        <div class={styles.methodologyCard}>
          <h3 class={styles.methodologyCardTitle}>Testing Conditions</h3>
          <ul class={styles.methodologyList}>
            <li>Mobile device emulation (Moto G Power)</li>
            <li>Simulated slow 4G throttling</li>
            <li>5 runs per site, averaged</li>
            <li>Scores recorded March 2026</li>
          </ul>
        </div>
        <div class={styles.methodologyCard}>
          <h3 class={styles.methodologyCardTitle}>What Each Score Means</h3>
          <ul class={styles.methodologyList}>
            <li><strong>Performance:</strong> Page load speed, interactivity, visual stability</li>
            <li><strong>Accessibility:</strong> WCAG compliance, screen reader support, color contrast</li>
            <li><strong>Best Practices:</strong> Security headers, HTTPS, modern APIs, no console errors</li>
            <li><strong>SEO:</strong> Crawlability, meta tags, structured data, mobile-friendliness</li>
          </ul>
        </div>
        <div class={styles.methodologyCard}>
          <h3 class={styles.methodologyCardTitle}>Why It Matters</h3>
          <ul class={styles.methodologyList}>
            <li>Google uses these metrics as ranking signals</li>
            <li>Faster sites convert more visitors into customers</li>
            <li>Accessible sites reach a wider audience</li>
            <li>Most small business sites score 40 to 60 on mobile</li>
          </ul>
        </div>
      </div>

      <p class={styles.methodologyNote}>
        Performance scores can vary slightly between runs due to network conditions and server
        response times. The scores shown here are rounded averages. Accessibility, Best Practices,
        and SEO scores are deterministic and consistent across runs.
      </p>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.cta}>
      <p class={styles.ctaText}>Want scores like these for your business?</p>
      <a href="/services/#contact" class={styles.ctaButton}>Get a Free Quote</a>
      <p style="margin-top: var(--space-md); font-size: 0.9rem; color: var(--text-secondary);">
        Read more: <a href="/blog/signs-your-business-website-needs-redesign/">Signs Your Website Needs a Redesign</a> &middot;
        <a href="/blog/rebuilding-critter-care-website/">Critter Care Case Study</a>
      </p>
    </section>
  </div>
</Layout>
