---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/services/ContactForm';
import styles from '../ServicesPage.module.css';
import FaqAccordion from '../../components/ui/FaqAccordion.astro';

const faqs = [
  {
    question: 'Boulder has a lot of tech-savvy consumers. Does that change how you build a website here?',
    answer:
      "It does. Boulder's audience has higher expectations for web experiences than most Colorado cities. They notice slow load times, dated designs, and clunky mobile experiences. They're also more likely to research a business thoroughly before choosing. I build sites that meet that standard: fast, modern, well-designed, and technically solid. If your site feels like it was built in 2018, Boulder customers will notice and move on.",
  },
  {
    question: 'My Pearl Street business gets a lot of foot traffic. Why do I need a website?',
    answer:
      "Foot traffic is great, but it's seasonal and limited to people physically walking by. A website extends your reach to CU students researching where to eat, tourists planning a Boulder trip, and locals who search before they leave the house. Even for businesses with strong foot traffic, a website with hours, menus, and online ordering captures the customers you're currently losing to competitors who show up in search results.",
  },
  {
    question: 'Can you build a website that reflects Boulder values like sustainability and community?',
    answer:
      "Boulder customers care about these things, and your website should reflect that. I'm not talking about slapping a green leaf icon on the page. I mean thoughtfully incorporating your sustainability practices, community involvement, and brand story into the content and design. A fast, lightweight site is also inherently more sustainable, as it uses less energy per page load than a bloated WordPress site.",
  },
  {
    question: 'I sell outdoor gear / run a fitness studio. Can you integrate booking or e-commerce?',
    answer:
      "Yes. Boulder's outdoor and wellness scene often needs functionality beyond a basic brochure site. I can build in online booking for classes and appointments, e-commerce for product sales, event registration, and integrations with tools you already use like Mindbody, Square, or Shopify. The key is building it lean so it loads fast, especially for mobile users who might be searching from the trailhead.",
  },
  {
    question: "You're based in the Denver area. Do you really know Boulder well enough?",
    answer:
      "I've spent plenty of time in Boulder and I know what makes it different from Denver. The culture, the customer expectations, the competitive landscape on Pearl Street versus a neighborhood business on Arapahoe. I drive up for in-person meetings whenever it's helpful. But honestly, the most important thing isn't whether I live on Mapleton Hill. It's whether I can build you a site that loads fast, looks great, and gets found by your customers. That's what I do.",
  },
];

const jsonLdService = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Bill Bergquist — Web Design in Boulder, CO',
  description:
    'Custom web design and development for small businesses in Boulder, Colorado. Fast, modern websites built by an experienced Front Range developer.',
  url: 'https://billbergquist.dev/services/boulder/',
  email: 'services@billbergquist.dev',
  telephone: '+1-847-280-0729',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Boulder',
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: 'Boulder',
    containedInPlace: { '@type': 'State', name: 'Colorado' },
  },
  provider: {
    '@id': 'https://billbergquist.dev/#person',
  },
  serviceType: ['Web Design', 'Web Development', 'Website Redesign', 'Landing Page Design'],
  priceRange: '$$',
  image: 'https://billbergquist.dev/og/services-boulder.png',
  dateModified: '2026-03-09',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web Development Services in Boulder',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Business Websites',
          description: 'Professional websites for Boulder small businesses. Fast, mobile-friendly, and built to convert.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Landing Pages',
          description: 'Focused, single-page sites designed to drive bookings, signups, or sales for Boulder businesses.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Website Redesign',
          description: 'Modernize your outdated website with a fresh design, faster performance, and better user experience.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Ongoing Support & Maintenance',
          description: 'Website updates, tweaks, and maintenance from a local Front Range developer you can reach out to anytime.',
        },
      },
    ],
  },
});

const jsonLdFaq = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
});

const bookingMonth = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toLocaleString('en-US', {
  month: 'long',
});
---

<Layout
  title="Web Design in Boulder, CO — Bill Bergquist"
  description="Custom web design for Boulder small businesses. Fast, beautiful websites built by an experienced Front Range developer. From Pearl Street to Flatirons."
  canonical="/services/boulder"
  jsonLd={[jsonLdService, jsonLdFaq]}
  ogImage="/og/services-boulder.png"
  geoRegion="US-CO"
  geoPlacename="Boulder, CO"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <h1 class={styles.title}>
        Web Design in Boulder, CO
      </h1>
      <p class={styles.subtitle}>Custom Websites for Boulder Small Businesses</p>
      <p class={styles.intro}>
        Boulder businesses operate at a different level. The customers here expect quality in your
        products, your services, and your online presence. A slow, generic template website doesn't
        match the standards of a town known for innovation, outdoor culture, and independent business.
        I build custom websites that match the quality Boulder customers expect.
      </p>
    </header>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Why Boulder Businesses Invest in Custom Websites
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Boulder customers have high standards</h3>
          <p class={styles.whyDescription}>
            Boulder folks notice quality. They can tell when a website was thrown together from a template.
            A site that's fast, well-designed, and clearly communicates what you do goes a long way,
            especially if you're in health, wellness, outdoor, or food.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Tourism drives online discovery</h3>
          <p class={styles.whyDescription}>
            Millions of visitors come to Boulder every year. They're searching on their phones for
            "best restaurants on Pearl Street" or "bike shops in Boulder." If your website isn't fast,
            mobile-friendly, and optimized for local search, you're invisible to visitors with money to spend.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Independent businesses deserve independent websites</h3>
          <p class={styles.whyDescription}>
            Boulder's identity is built on independent businesses, not chains. Your website should
            feel like yours, not like every other Squarespace site on the internet.
            A custom site gives you that.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Front Range developer, not a distant agency</h3>
          <p class={styles.whyDescription}>
            I'm based in the Denver metro area, 30 minutes from Boulder. I know the Front Range market
            and I'm available for in-person meetings. You get senior-level engineering (14+ years) without
            the overhead of a downtown agency charging $20,000+ for the same work.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Boulder Businesses I Work With
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Outdoor recreation & gear</h3>
          <p class={styles.whyDescription}>
            Bike shops, climbing gyms, running stores, outdoor outfitters. Boulder is the outdoor
            capital of Colorado, and your website needs to match that reputation. I build sites with
            product showcases, event calendars, and the SEO that captures searches like "bike shop
            near Boulder."
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Health, wellness & yoga</h3>
          <p class={styles.whyDescription}>
            Boulder has more wellness practitioners per capita than almost anywhere. Yoga studios,
            acupuncturists, massage therapists, nutritionists. A clean website with online booking,
            practitioner bios, and class schedules helps you stand out in a crowded market.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Tech startups & SaaS</h3>
          <p class={styles.whyDescription}>
            Boulder's tech scene is serious. Startups, SaaS companies, and consulting firms need
            websites that signal credibility to investors, customers, and talent. I build clean,
            fast sites that feel like they belong to a company that knows what it's doing.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Restaurants & craft breweries</h3>
          <p class={styles.whyDescription}>
            Pearl Street restaurants, breweries on Walnut, coffee shops on the Hill. Boulder's food
            scene attracts both locals and tourists. I build sites with menus, hours, reservation
            links, and the local SEO that gets you found by visitors planning their Boulder trip.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.faq}>
      <h2 class={styles.sectionTitle}>
        Frequently Asked Questions
      </h2>
      <FaqAccordion faqs={faqs} />
    </section>

    <p class={styles.perfLink}>
      Want a quick ballpark? <a href="/services/estimate/">Try the cost calculator &rarr;</a>
    </p>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>Related Reading</h2>
      <div class={styles.faqList}>
        <div class={styles.faqItem}>
          <a href="/blog/how-much-does-a-website-cost-denver/">How Much Does a Website Cost in Denver?</a>
          <p class={styles.faqAnswer}>Pricing applies across the Front Range. A detailed breakdown of what to expect.</p>
        </div>
        <div class={styles.faqItem}>
          <a href="/blog/template-vs-custom-website/">Template vs. Custom Website: Which Is Right for Your Business?</a>
          <p class={styles.faqAnswer}>Boulder businesses often debate this. Here's how to decide.</p>
        </div>
        <div class={styles.faqItem}>
          <a href="/blog/signs-your-business-website-needs-redesign/">Signs Your Business Website Needs a Redesign</a>
          <p class={styles.faqAnswer}>Not sure if your current site is holding you back? Here are the telltale signs.</p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.areasServed}>
      <h2 class={styles.sectionTitle}>
        Also Serving Nearby
      </h2>
      <div class={styles.areasGrid}>
        <a href="/services/denver/" class={styles.areaLink}>Denver</a>
        <a href="/services/westminster/" class={styles.areaLink}>Westminster</a>
        <a href="/services/arvada/" class={styles.areaLink}>Arvada</a>
        <a href="/services/golden/" class={styles.areaLink}>Golden</a>
        <a href="/services/lakewood/" class={styles.areaLink}>Lakewood</a>
        <span class={styles.areaText}>Broomfield</span>
        <span class={styles.areaText}>Louisville</span>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.contact}>
      <h2 class={styles.sectionTitle}>
        Let's Build Your Boulder Website
      </h2>
      <p class={styles.contactIntro}>
        Whether you run a Pearl Street boutique, a yoga studio on Arapahoe, a restaurant in
        North Boulder, or any other local business, I'd love to hear about your project.
      </p>

      <div class={styles.trustSignals}>
        <span class={styles.trustItem}>&#10003; Currently booking for {bookingMonth}</span>
        <span class={styles.trustItem}>&#10003; Free consultation, no obligation</span>
        <span class={styles.trustItem}>&#10003; Response within 1 business day</span>
        <a href="https://share.google/AN9wq1GbXPqjeQwEf" target="_blank" rel="noopener noreferrer" class={styles.trustItem}>
          &#10003; View my Google Business Profile
        </a>
      </div>

      <ContactForm client:visible />

      <div class={styles.emailAlt}>
        <p>
          Prefer to reach out directly?{' '}
          <a href="tel:+18472800729" class={styles.emailLink}>(847) 280-0729</a>{' '}
          or{' '}
          <a href="mailto:services@billbergquist.dev" class={styles.emailLink}>
            services@billbergquist.dev
          </a>
        </p>
        <p style="margin-top: var(--space-md);">
          <a href="/services/" class={styles.emailLink}>&larr; Back to all services</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
