---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/services/ContactForm';
import styles from '../ServicesPage.module.css';

const faqs = [
  {
    question: 'How much does a website cost for a Golden business?',
    answer:
      "Most sites I build for small businesses cost between $2,000 and $8,000. Tourism and outdoor businesses sometimes need booking integrations or seasonal content, which can affect scope. Try the cost calculator to get a ballpark, or reach out and I'll give you a clear estimate.",
  },
  {
    question: 'Can you build a website that handles seasonal traffic for my Golden business?',
    answer:
      "Yes. Golden gets huge surges of visitors during summer hiking season, fall colors, and holiday events. I build sites that load fast under traffic spikes and are easy to update with seasonal hours, menus, or event information.",
  },
  {
    question: 'Do you understand the Golden market?',
    answer:
      "I do. Golden is different from Denver. It's a small mountain town with a strong local identity, a major university, and a steady stream of tourists. I build sites that speak to both locals and visitors, not generic Denver-area templates.",
  },
];

const jsonLdService = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Bill Bergquist — Web Design in Golden, CO',
  description:
    'Custom web design and development for small businesses in Golden, Colorado. Fast, modern websites built by a local Front Range developer.',
  url: 'https://billbergquist.dev/services/golden/',
  email: 'services@billbergquist.dev',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Golden',
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: 'Golden',
    containedInPlace: { '@type': 'State', name: 'Colorado' },
  },
  provider: {
    '@id': 'https://billbergquist.dev/#person',
  },
  serviceType: ['Web Design', 'Web Development', 'Website Redesign', 'Landing Page Design'],
  priceRange: '$$',
  image: 'https://billbergquist.dev/og/services-golden.png',
  foundingDate: '2026-02-25',
  dateModified: '2026-03-09',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web Development Services in Golden',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Business Websites',
          description: 'Professional websites for Golden small businesses. Fast, mobile-friendly, and built to convert.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Landing Pages',
          description: 'Focused, single-page sites designed to drive bookings, signups, or sales for Golden businesses.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Website Redesign',
          description: 'Modernize your outdated website with a fresh design, faster performance, and better user experience.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Ongoing Support & Maintenance',
          description: 'Website updates, tweaks, and maintenance from a local Front Range developer you can reach out to anytime.',
        },
      },
    ],
  },
});

const jsonLdFaq = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
});

const bookingMonth = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toLocaleString('en-US', {
  month: 'long',
});
---

<Layout
  title="Web Design in Golden, CO — Bill Bergquist"
  description="Custom web design for Golden small businesses. Fast, modern websites for restaurants, outdoor companies, and local shops on Washington Avenue and beyond."
  canonical="/services/golden"
  jsonLd={[jsonLdService, jsonLdFaq]}
  ogImage="/og/services-golden.png"
  geoRegion="US-CO"
  geoPlacename="Golden, CO"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <h1 class={styles.title}>
        Web Design in Golden, CO
      </h1>
      <p class={styles.subtitle}>Custom Websites for Golden Small Businesses</p>
      <p class={styles.intro}>
        Golden is one of those places that feels nothing like the rest of the Denver metro. It has a
        small-town mountain feel, a world-class university, a thriving downtown on Washington Avenue,
        and a constant flow of tourists hitting the trails, the breweries, and Clear Creek. If you run
        a business here, your website needs to reflect that unique character and reach both locals and
        the visitors passing through.
      </p>
    </header>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Why Golden Businesses Need Strong Websites
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Tourists search before they visit</h3>
          <p class={styles.whyDescription}>
            People planning a day trip to Golden are Googling "best restaurants in Golden CO" and
            "things to do in Golden" before they leave home. A fast, well-optimized website puts
            your business in front of visitors who are ready to spend money.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Washington Avenue is competitive</h3>
          <p class={styles.whyDescription}>
            Golden's downtown strip is packed with restaurants, shops, and galleries competing for
            attention. A generic website doesn't cut it when the business two doors down has a
            polished online presence. Your site needs to match the quality of your storefront.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Mines students and staff are a built-in audience</h3>
          <p class={styles.whyDescription}>
            Colorado School of Mines brings thousands of students, faculty, and visiting families to
            Golden year-round. This is a tech-savvy audience that expects modern, fast websites.
            If your site feels outdated, they'll move on.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Close enough to meet in person</h3>
          <p class={styles.whyDescription}>
            I'm based in the Lakewood area, about 15 minutes from Golden. I can meet you on
            Washington Ave, at your business, or wherever works. You get a local developer who
            knows the Front Range, not a remote agency guessing at your market.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>
        Golden Businesses I Work With
      </h2>
      <div class={styles.whyGrid}>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Outdoor recreation & adventure</h3>
          <p class={styles.whyDescription}>
            Bike shops, climbing gyms, outfitters, guided tour companies. Golden is a gateway to the
            mountains, and outdoor businesses need sites that showcase their offerings, handle
            bookings, and rank for searches like "mountain biking near Golden CO."
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Restaurants & breweries</h3>
          <p class={styles.whyDescription}>
            Golden's food and drink scene punches above its weight. From downtown restaurants to
            taprooms along the creek, I build sites with menus, hours, reservation links, and the
            local SEO that gets you into "best food in Golden" search results.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Tourism & hospitality</h3>
          <p class={styles.whyDescription}>
            Hotels, B&Bs, event venues, wedding locations. Golden's tourism industry needs websites
            that look beautiful, load fast on mobile, and make booking easy. I build sites designed
            to convert visitors into guests.
          </p>
        </div>
        <div class={styles.whyItem}>
          <h3 class={styles.whyTitle}>Professional services & tech</h3>
          <p class={styles.whyDescription}>
            Engineering firms, consultancies, and tech companies. Golden's proximity to Mines means
            there's a concentration of technical talent and businesses here. A sharp website signals
            competence to clients who understand quality.
          </p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.faq}>
      <h2 class={styles.sectionTitle}>
        Frequently Asked Questions
      </h2>
      <div class={styles.faqList}>
        {
          faqs.map((faq) => (
            <div class={styles.faqItem}>
              <h3 class={styles.faqQuestion}>{faq.question}</h3>
              <p class={styles.faqAnswer}>{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </section>

    <p class={styles.perfLink}>
      Want a quick ballpark? <a href="/services/estimate/">Try the cost calculator &rarr;</a>
    </p>

    <div class={styles.divider}></div>

    <section class={styles.whySection}>
      <h2 class={styles.sectionTitle}>Related Reading</h2>
      <div class={styles.faqList}>
        <div class={styles.faqItem}>
          <a href="/blog/how-much-does-a-website-cost-denver/">How Much Does a Website Cost in Denver?</a>
          <p class={styles.faqAnswer}>Pricing applies across the Front Range, including Golden. See the full breakdown.</p>
        </div>
        <div class={styles.faqItem}>
          <a href="/blog/signs-your-business-website-needs-redesign/">Signs Your Business Website Needs a Redesign</a>
          <p class={styles.faqAnswer}>Not sure if your current site is holding you back? Here are the telltale signs.</p>
        </div>
        <div class={styles.faqItem}>
          <a href="/blog/template-vs-custom-website/">Template vs. Custom Website: Which Is Right for Your Business?</a>
          <p class={styles.faqAnswer}>Understand the trade-offs before deciding how to build your next site.</p>
        </div>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.areasServed}>
      <h2 class={styles.sectionTitle}>
        Also Serving Nearby
      </h2>
      <div class={styles.areasGrid}>
        <a href="/services/denver/" class={styles.areaLink}>Denver</a>
        <a href="/services/lakewood/" class={styles.areaLink}>Lakewood</a>
        <a href="/services/arvada/" class={styles.areaLink}>Arvada</a>
        <a href="/services/boulder/" class={styles.areaLink}>Boulder</a>
        <a href="/services/littleton/" class={styles.areaLink}>Littleton</a>
        <span class={styles.areaText}>Wheat Ridge</span>
        <span class={styles.areaText}>Edgewater</span>
        <span class={styles.areaText}>Morrison</span>
      </div>
    </section>

    <div class={styles.divider}></div>

    <section class={styles.contact}>
      <h2 class={styles.sectionTitle}>
        Let's Build Your Golden Website
      </h2>
      <p class={styles.contactIntro}>
        Whether you run an outdoor shop near Clear Creek, a restaurant on Washington Avenue, a
        professional services firm, or any other Golden business, I'd love to hear about your project.
      </p>

      <div class={styles.trustSignals}>
        <span class={styles.trustItem}>&#10003; Currently booking for {bookingMonth}</span>
        <span class={styles.trustItem}>&#10003; Free consultation, no obligation</span>
        <span class={styles.trustItem}>&#10003; Response within 1 business day</span>
      </div>

      <ContactForm client:visible />

      <div class={styles.emailAlt}>
        <p>
          Prefer email?{' '}
          <a href="mailto:services@billbergquist.dev" class={styles.emailLink}>
            services@billbergquist.dev
          </a>
        </p>
        <p style="margin-top: var(--space-md);">
          <a href="/services/" class={styles.emailLink}>&larr; Back to all services</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
