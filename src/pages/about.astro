---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import GlowText from '../components/ui/GlowText.astro';
import SectionDivider from '../components/ui/SectionDivider.astro';
import ExperienceTimeline from '../components/about/ExperienceTimeline.astro';
import SkillsSection from '../components/about/SkillsSection.astro';
import headshot from '../assets/headshot.png';
import styles from './AboutPage.module.css';

const jsonLdPerson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://billbergquist.dev/#person',
  name: 'Bill Bergquist',
  jobTitle: 'Staff Software Engineer',
  description: 'Staff Software Engineer with 14+ years of experience. Web developer in Denver, CO specializing in React, TypeScript, and modern web applications for small businesses.',
  url: 'https://billbergquist.dev',
  image: 'https://billbergquist.dev/og/about.png',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Denver',
    addressRegion: 'CO',
    addressCountry: 'US',
  },
  sameAs: [
    'https://github.com/titomb345',
    'https://www.linkedin.com/in/bill-bergquist/',
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'Kasa',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'Purdue University',
  },
  knowsAbout: [
    'React',
    'TypeScript',
    'Node.js',
    'Frontend Architecture',
    'Web Development',
    'Astro',
  ],
});
---

<Layout
  title="About Bill Bergquist — Staff Software Engineer"
  description="14+ years of full-stack experience. Currently Staff Engineer at Kasa, building React applications and leading frontend architecture."
  canonical="/about"
  jsonLd={[jsonLdPerson]}
  ogImage="/og/about.png"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <Image
        src={headshot}
        alt="Bill Bergquist — Staff Software Engineer"
        width={200}
        height={200}
        class={styles.headshot}
      />
      <GlowText size="large" color="mint" class={styles.title}>ABOUT ME</GlowText>
      <p class={styles.summary}>
        I'm a Staff Software Engineer with over 14 years of experience building web applications.
        While my roots are in frontend technologies, I've been diving deeper into full stack
        development, working across the entire stack to build internal tooling and developer
        experiences that help teams ship faster and more confidently.
      </p>
      <p class={styles.summary}>
        Currently at Kasa, I lead frontend architecture initiatives and build tools that accelerate
        development across the organization. I'm passionate about clean code, great user experiences,
        and helping other engineers grow.
      </p>
      <p class={styles.aiHighlight}>
        I embrace AI as a force multiplier in my workflow. Using Claude Code, I leverage agentic
        workflows and prompt engineering to accelerate development, automate repetitive tasks, and
        explore solutions faster than ever before.
      </p>
    </header>

    <main class={styles.content}>
      <ExperienceTimeline />
      <SectionDivider color="mint" />
      <SkillsSection />
      <SectionDivider color="purple" />

      <section class={styles.education}>
        <GlowText as="h2" size="medium" color="purple" class={styles.sectionTitle}>
          EDUCATION
        </GlowText>
        <div class={styles.educationCard}>
          <h3 class={styles.school}>Purdue University</h3>
          <p class={styles.degree}>BS Computer Engineering</p>
          <p class={styles.years}>2006 - 2010</p>
        </div>
      </section>

      <SectionDivider color="orange" />

      <section class={styles.approach}>
        <GlowText as="h2" size="medium" color="orange" class={styles.sectionTitle}>
          MY APPROACH
        </GlowText>
        <p class={styles.approachText}>
          I believe good software comes from understanding the problem before writing a single line of code.
          Whether I'm building internal tooling for a product team or a website for a local business, I start
          by listening. What does the user actually need? What does success look like? Then I choose the
          simplest technology that gets the job done well.
        </p>
        <p class={styles.approachText}>
          I'm opinionated about code quality: clean abstractions, meaningful tests, and documentation that
          actually helps. But I'm not precious about tools. React, Vue, Astro, vanilla JavaScript... the right
          choice depends on the project, not personal preference. I care about shipping things that work,
          load fast, and are maintainable by whoever comes next.
        </p>
        <p class={styles.approachText}>
          I also build <a href="/arcade/">browser games</a> in my spare time as a way to explore new
          technologies and keep building things that are just fun.
        </p>
      </section>

      <section class={styles.servicesCta}>
        <p class={styles.servicesCtaText}>
          If you're a small business in Denver or the Colorado Front Range looking for a website, I'd love to help.
          I bring the same engineering standards from my enterprise work to every client project.
        </p>
        <a href="/services/" class={styles.servicesCtaLink}>View My Services &rarr;</a>
      </section>
    </main>
  </div>
</Layout>
