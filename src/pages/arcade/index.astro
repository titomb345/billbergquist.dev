---
import Layout from '../../layouts/Layout.astro';
import DescentGameCard from '../../components/games/DescentGameCard.astro';
import GridlockGameCard from '../../components/games/GridlockGameCard.astro';
import CrapsGameCard from '../../components/games/CrapsGameCard.astro';
import styles from '../ArcadePage.module.css';

const jsonLdArcade = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Arcade — Browser Games by Bill Bergquist',
  description: 'Browser-based games built through AI-assisted development. Play free in your browser.',
  url: 'https://billbergquist.dev/arcade/',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        item: {
          '@type': 'SoftwareApplication',
          name: 'Minesweeper: Descent',
          applicationCategory: 'Game',
          operatingSystem: 'Web Browser',
          url: 'https://billbergquist.dev/arcade/descent/',
          description: 'Roguelike minesweeper. Descend 10 floors of escalating danger. Collect power-ups to survive.',
          offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
          author: { '@id': 'https://billbergquist.dev/#person' },
        },
      },
      {
        '@type': 'ListItem',
        position: 2,
        item: {
          '@type': 'SoftwareApplication',
          name: 'Gridlock: Showdown',
          applicationCategory: 'Game',
          operatingSystem: 'Web Browser',
          url: 'https://billbergquist.dev/arcade/gridlock/',
          description: 'Classic falling-blocks puzzle. Stack blocks, clear lines, and compete on the global leaderboard.',
          offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
          author: { '@id': 'https://billbergquist.dev/#person' },
        },
      },
      {
        '@type': 'ListItem',
        position: 3,
        item: {
          '@type': 'SoftwareApplication',
          name: 'Craps: High Roller',
          applicationCategory: 'Game',
          operatingSystem: 'Web Browser',
          url: 'https://billbergquist.dev/craps/',
          description: 'Roll the bones with up to 4 friends. Real-time multiplayer craps with full betting.',
          offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
          author: { '@id': 'https://billbergquist.dev/#person' },
        },
      },
    ],
  },
});
---

<Layout
  title="Arcade — Browser Games by Bill Bergquist"
  description="Browser-based games built through AI-assisted development. Play Minesweeper: Descent, Gridlock: Showdown, and Craps: High Roller, free in your browser."
  canonical="/arcade"
  jsonLd={[jsonLdArcade]}
  ogImage="/og/arcade.png"
>
  <div class={styles.page}>
    <!-- CRT scanline overlay -->
    <div class={styles.scanlines} aria-hidden="true"></div>

    <!-- Marquee ticker -->
    <div class={styles.marquee} aria-hidden="true">
      <div class={styles.marqueeTrack}>
        <span>INSERT COIN</span>
        <span class={styles.marqueeDot}></span>
        <span>PLAYER 1 READY</span>
        <span class={styles.marqueeDot}></span>
        <span>HIGH SCORE: ???</span>
        <span class={styles.marqueeDot}></span>
        <span>INSERT COIN</span>
        <span class={styles.marqueeDot}></span>
        <span>PLAYER 1 READY</span>
        <span class={styles.marqueeDot}></span>
        <span>HIGH SCORE: ???</span>
        <span class={styles.marqueeDot}></span>
      </div>
    </div>

    <header class={styles.header}>
      <h1 class="glitch-text" data-text="ARCADE">ARCADE</h1>
      <p class={styles.subtitle}>
        Welcome to my arcade—a collection of browser-based games built entirely through{' '}
        <span class="neon-text-orange">AI-assisted development</span>. These projects are my
        playground for exploring agentic workflows, pushing the boundaries of what's possible when
        combining rapid prototyping with tools like{' '}
        <span class="neon-text-orange">Claude Code</span>. Gaming has always been a passion of
        mine, and this is where that passion meets cutting-edge development techniques.
      </p>
      <div class="accent-line-orange"></div>
    </header>

    <section class={styles.grid}>
      <div class={styles.cabinetFrame}>
        <DescentGameCard />
      </div>
      <div class={styles.cabinetFrame}>
        <GridlockGameCard />
      </div>
      <div class={styles.cabinetFrame}>
        <CrapsGameCard />
      </div>
    </section>
  </div>
</Layout>
