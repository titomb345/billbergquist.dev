---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { BASE_URL } from '../../shared/site';
import { tagSlug } from '../../shared/utils/slugify';
import { stripExt, formatDate } from '../../shared/utils/content';
import styles from './BlogPage.module.css';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featuredPost = allPosts.find((post) => post.data.featured);
const posts = allPosts.filter((post) => post !== featuredPost);

const jsonLdBlog = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog — Bill Bergquist',
  description: 'Articles on web development, small business websites, and local SEO for Denver and the Colorado Front Range.',
  url: `${BASE_URL}/blog/`,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: allPosts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${BASE_URL}/blog/${stripExt(post.id)}/`,
      name: post.data.title,
    })),
  },
});
---

<Layout
  title="Blog — Web Development & Local SEO | Bill Bergquist"
  description="Articles on web development, small business websites, and local SEO for Denver and the Colorado Front Range."
  canonical="/blog"
  jsonLd={[jsonLdBlog]}
  ogImage="/og/blog.png"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <h1 class={styles.title}>My Blog</h1>
      <p class={styles.intro}>
        Thoughts on web development, building websites for small businesses, and what I've learned
        from 14+ years of engineering for the web.
      </p>
    </header>

    {allPosts.length === 0 ? (
      <p class={styles.empty}>Posts coming soon. Check back shortly.</p>
    ) : (
      <>
        {featuredPost && (
          <a href={`/blog/${stripExt(featuredPost.id)}/`} class={styles.featured}>
            <span class={styles.featuredLabel}>Featured</span>
            <h2 class={styles.featuredTitle}>{featuredPost.data.title}</h2>
            <p class={styles.featuredDescription}>{featuredPost.data.description}</p>
            <div class={styles.featuredMeta}>
              <time datetime={featuredPost.data.publishDate.toISOString()} class={styles.cardDate}>
                {formatDate(featuredPost.data.publishDate, 'short')}
              </time>
              <div class={styles.cardTags}>
                {featuredPost.data.tags.slice(0, 3).map((tag) => (
                  <span class={styles.cardTag} data-tag-href={`/blog/tag/${tagSlug(tag)}/`}>{tag}</span>
                ))}
              </div>
            </div>
          </a>
        )}

        {posts.length > 0 && (
          <div class={styles.grid}>
            {posts.map((post) => (
              <a href={`/blog/${stripExt(post.id)}/`} class={styles.card}>
                <div class={styles.cardMeta}>
                  <time datetime={post.data.publishDate.toISOString()} class={styles.cardDate}>
                    {formatDate(post.data.publishDate, 'short')}
                  </time>
                  <div class={styles.cardTags}>
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class={styles.cardTag} data-tag-href={`/blog/tag/${tagSlug(tag)}/`}>{tag}</span>
                    ))}
                  </div>
                </div>
                <h2 class={styles.cardTitle}>{post.data.title}</h2>
                <p class={styles.cardDescription}>{post.data.description}</p>
              </a>
            ))}
          </div>
        )}
      </>
    )}
  </div>

  <script>
    document.querySelectorAll('[data-tag-href]').forEach((tag) => {
      tag.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const href = (tag as HTMLElement).dataset.tagHref;
        if (href) window.location.href = href;
      });
    });
  </script>
</Layout>
