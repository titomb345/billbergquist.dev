---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import styles from '../BlogPage.module.css';
import { tagSlug } from '../../../shared/utils/slugify';
import { stripExt, formatDate } from '../../../shared/utils/content';
import { BASE_URL } from '../../../shared/site';

const TAG_LABELS: Record<string, string> = {
  seo: 'SEO',
};

function formatTagLabel(tag: string): string {
  if (TAG_LABELS[tag]) return TAG_LABELS[tag];
  return tag
    .split(' ')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag);
    }
  }

  return Array.from(tagSet).map((tag) => ({
    params: { tag: tagSlug(tag) },
    props: { originalTag: tag },
  }));
}

const { originalTag } = Astro.props;
const { tag } = Astro.params;
const label = formatTagLabel(originalTag);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((post) => post.data.tags.includes(originalTag))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const jsonLdTag = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${label} — Blog — Bill Bergquist`,
  description: `Blog posts tagged "${label}" by Bill Bergquist.`,
  url: `${BASE_URL}/blog/tag/${tag}/`,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${BASE_URL}/blog/${stripExt(post.id)}/`,
      name: post.data.title,
    })),
  },
});
---

<Layout
  title={`${label} — Blog — Bill Bergquist`}
  description={`Blog posts tagged "${label}" by Bill Bergquist.`}
  canonical={`/blog/tag/${tag}`}
  noindex={true}
  jsonLd={[jsonLdTag]}
  ogImage="/og/blog.png"
>
  <div class={styles.page}>
    <header class={styles.header}>
      <h1 class={styles.title}>{label}</h1>
      <p class={styles.intro}>
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged "{label}"
      </p>
      <p class={styles.backLink}>
        <a href="/blog/">&larr; All posts</a>
      </p>
    </header>

    <div class={styles.grid}>
      {posts.map((post) => (
        <a href={`/blog/${stripExt(post.id)}/`} class={styles.card}>
          <div class={styles.cardMeta}>
            <time datetime={post.data.publishDate.toISOString()} class={styles.cardDate}>
              {formatDate(post.data.publishDate, 'short')}
            </time>
            <div class={styles.cardTags}>
              {post.data.tags.slice(0, 3).map((t) => (
                <span class={styles.cardTag}>{t}</span>
              ))}
            </div>
          </div>
          <h2 class={styles.cardTitle}>{post.data.title}</h2>
          <p class={styles.cardDescription}>{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
