---
import ScrollProgress from '../components/layout/ScrollProgress.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import { BASE_URL } from '../shared/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  jsonLd?: string[];
  geoRegion?: string;
  geoPlacename?: string;
  ogImage?: string;
  hideBreadcrumbs?: boolean;
  breadcrumbTitle?: string;
  ogType?: string;
  articlePublishedTime?: string;
  articleAuthor?: string;
}

const { title, description, canonical, noindex = false, jsonLd = [], geoRegion, geoPlacename, ogImage, hideBreadcrumbs = false, breadcrumbTitle, ogType = 'website', articlePublishedTime, articleAuthor } = Astro.props;

const OG_IMAGE = ogImage ? `${BASE_URL}${ogImage}` : `${BASE_URL}/og-image.png`;
// Ensure canonical URL always has a trailing slash (matches Netlify's enforced trailing slashes)
const normalizedCanonical = canonical && canonical !== '/' && !canonical.endsWith('/') ? `${canonical}/` : canonical;
const url = normalizedCanonical ? `${BASE_URL}${normalizedCanonical}` : `${BASE_URL}/`;

const breadcrumbNames: Record<string, string> = {
  about: 'About',
  portfolio: 'Portfolio',
  services: 'Services',
  denver: 'Denver',
  lakewood: 'Lakewood',
  boulder: 'Boulder',
  arvada: 'Arvada',
  golden: 'Golden',
  littleton: 'Littleton',
  aurora: 'Aurora',
  westminster: 'Westminster',
  'highlands-ranch': 'Highlands Ranch',
  blog: 'Blog',
  tag: 'Tag',
  privacy: 'Privacy Policy',
  arcade: 'Arcade',
  descent: 'Minesweeper: Descent',
  gridlock: 'Gridlock',
  retro: 'Retro',
  performance: 'Performance',
  estimate: 'Cost Estimator',
};

// Segments to skip in breadcrumb display (no landing page exists)
const breadcrumbSkip = new Set(['tag']);

function buildBreadcrumbs(path?: string, lastSegmentName?: string, absolute = false) {
  const prefix = absolute ? BASE_URL : '';
  const items: { name: string; url: string }[] = [{ name: 'Home', url: `${prefix}/` }];
  if (path && path !== '/') {
    const segments = path.replace(/^\//, '').replace(/\/$/, '').split('/');
    let accumulated = '';
    for (let i = 0; i < segments.length; i++) {
      const seg = segments[i];
      accumulated += `/${seg}`;
      if (breadcrumbSkip.has(seg)) continue;
      const isLast = i === segments.length - 1;
      const name = isLast && lastSegmentName ? lastSegmentName : breadcrumbNames[seg] || seg;
      items.push({ name, url: `${prefix}${accumulated}/` });
    }
  }
  return items;
}

const breadcrumbs = buildBreadcrumbs(canonical, breadcrumbTitle);
const breadcrumbsAbsolute = buildBreadcrumbs(canonical, breadcrumbTitle, true);
const breadcrumbLd = breadcrumbsAbsolute.length > 1 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbsAbsolute.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
}) : null;

const allJsonLd = breadcrumbLd ? [...jsonLd, breadcrumbLd] : jsonLd;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0d0d14" />
    <meta name="author" content="Bill Bergquist" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- RSS feed -->
    <link rel="alternate" type="application/rss+xml" title="Bill Bergquist — Blog" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Bill Bergquist" />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:url" content={url} />
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleAuthor && <meta property="article:author" content={articleAuthor} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <link rel="canonical" href={url} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {geoRegion && <meta name="geo.region" content={geoRegion} />}
    {geoPlacename && <meta name="geo.placename" content={geoPlacename} />}

    {
      allJsonLd.map((ld) => (
        <script type="application/ld+json" set:html={ld} />
      ))
    }

    <slot name="head" />
  </head>
  <body>
    <div class="layout">
      <ScrollProgress />

      <!-- SVG noise texture -->
      <svg class="noise" aria-hidden="true" width="100%" height="100%">
        <filter id="noiseFilter">
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.9"
            numOctaves="4"
            stitchTiles="stitch"></feTurbulence>
        </filter>
        <rect width="100%" height="100%" filter="url(#noiseFilter)"></rect>
      </svg>

      <!-- Atmospheric gradient orbs -->
      <div class="atmosphereOrb orbOrange" aria-hidden="true"></div>
      <div class="atmosphereOrb orbMagenta" aria-hidden="true"></div>

      <Navbar />
      <main class="main">
        {!hideBreadcrumbs && breadcrumbs.length > 2 && (
          <div class="breadcrumbs-wrapper">
            <Breadcrumbs items={breadcrumbs} />
          </div>
        )}
        <slot />
      </main>
      <Footer />
    </div>

    <script src="../scripts/scroll-reveal.ts"></script>

    <style>
      .layout {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background-color: var(--bg-primary);
        position: relative;
        overflow-x: clip;
      }

      /* Grid background */
      .layout::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
          linear-gradient(90deg, transparent 49%, rgba(0, 201, 167, 0.03) 50%, transparent 51%),
          linear-gradient(0deg, transparent 49%, rgba(0, 201, 167, 0.03) 50%, transparent 51%);
        background-size: 50px 50px;
        pointer-events: none;
        z-index: 0;
      }

      /* Vignette overlay */
      .layout::after {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(ellipse at center, transparent 50%, rgba(10, 10, 15, 0.4) 100%);
        pointer-events: none;
        z-index: 0;
      }

      .main {
        flex: 1;
        position: relative;
        z-index: 1;
      }

      .breadcrumbs-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: var(--space-md) var(--space-lg) 0;
      }

      /* Noise texture overlay */
      .noise {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        z-index: 0;
        opacity: 0.03;
      }

      /* Gradient mesh orbs */
      .atmosphereOrb {
        position: fixed;
        border-radius: 50%;
        filter: blur(100px);
        pointer-events: none;
        z-index: 0;
        opacity: 0.06;
      }

      .orbOrange {
        width: 500px;
        height: 500px;
        top: 10%;
        right: -10%;
        background: radial-gradient(circle, var(--neon-orange), transparent 70%);
      }

      .orbMagenta {
        width: 400px;
        height: 400px;
        bottom: 20%;
        left: -8%;
        background: radial-gradient(circle, var(--neon-magenta), transparent 70%);
      }

      @media (max-width: 768px) {
        .atmosphereOrb {
          opacity: 0.04;
        }

        .orbOrange {
          width: 300px;
          height: 300px;
        }

        .orbMagenta {
          width: 250px;
          height: 250px;
        }
      }
    </style>
    <!-- Konami code easter egg -->
    <script is:inline>
      (function() {
        var seq = [38,38,40,40,37,39,37,39,66,65];
        var pos = 0;
        document.addEventListener('keydown', function(e) {
          if (e.keyCode === seq[pos]) {
            pos++;
            if (pos === seq.length) {
              pos = 0;
              window.location.href = '/arcade/?konami=1';
            }
          } else {
            pos = 0;
          }
        });
      })();
    </script>
    <!-- Cloudflare Web Analytics -->
    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "df38e71453b142fa930d170f559fe7bf"}'></script>
  </body>
</html>
