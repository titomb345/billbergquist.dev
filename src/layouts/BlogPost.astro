---
import Layout from './Layout.astro';
import styles from './BlogPost.module.css';
import { BASE_URL, PERSON_REF } from '../shared/site';
import { tagSlug } from '../shared/utils/slugify';
import { formatDate } from '../shared/utils/content';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  tags: string[];
  ogImage?: string;
  slug: string;
  readingTime?: number;
}

const { title, description, publishDate, updatedDate, tags, ogImage, slug, readingTime } = Astro.props;

const formattedDate = formatDate(publishDate);
const formattedUpdated = updatedDate ? formatDate(updatedDate) : undefined;

const articleImage = ogImage ? `${BASE_URL}${ogImage}` : `${BASE_URL}/og/blog.png`;

const jsonLdArticle = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: articleImage,
  datePublished: publishDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: PERSON_REF,
  publisher: PERSON_REF,
  mainEntityOfPage: `${BASE_URL}/blog/${slug}/`,
});
---

<Layout
  title={title}
  description={description}
  canonical={`/blog/${slug}`}
  jsonLd={[jsonLdArticle]}
  ogImage={ogImage || '/og/blog.png'}
  breadcrumbTitle={title}
  ogType="article"
  articlePublishedTime={publishDate.toISOString()}
  articleAuthor={`${BASE_URL}/about/`}
>
  <article class={styles.article}>
    <header class={styles.header}>
      <h1 class={styles.title}>{title}</h1>
      <div class={styles.meta}>
        <time datetime={publishDate.toISOString()} class={styles.date}>{formattedDate}</time>
        {formattedUpdated && (
          <span class={styles.updated}>(Updated {formattedUpdated})</span>
        )}
        {readingTime && (
          <span class={styles.readingTime}>{readingTime} min read</span>
        )}
      </div>
      <div class={styles.tags}>
        {tags.map((tag) => (
          <a href={`/blog/tag/${tagSlug(tag)}/`} class={styles.tag}>{tag}</a>
        ))}
      </div>
    </header>

    <div class={styles.content}>
      <slot />
    </div>

    <div class={styles.divider}></div>

    <aside class={styles.ctaBox}>
      <p class={styles.ctaHeading}>Need a website for your business?</p>
      <p class={styles.ctaText}>
        I build fast, custom websites for small businesses in Denver and the Colorado Front Range.
        Free consultation, no obligation.
      </p>
      <div class={styles.ctaLinks}>
        <a href="/services/" class={styles.ctaLink}>View Services &rarr;</a>
        <a href="/services/estimate/" class={styles.ctaLinkSecondary}>Try the Cost Calculator &rarr;</a>
      </div>
    </aside>

    <div class={styles.authorBox}>
      <div class={styles.authorInfo}>
        <p class={styles.authorName}>Bill Bergquist</p>
        <p class={styles.authorRole}>Web developer in Denver with 14+ years of experience building for the web.</p>
        <a href="/about/" class={styles.authorLink}>More about me &rarr;</a>
      </div>
    </div>
  </article>

</Layout>
